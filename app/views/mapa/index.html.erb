<div style="position: fixed; top: 57px; left: 0; right: 0; bottom: 0; z-index: 40;">
  <div id="mapa-container" style="width: 100%; height: 100%; background: #1a1a2e;"></div>
</div>

<div id="tooltip" style="
  display: none;
  position: fixed;
  background: rgba(0,0,0,0.75);
  color: white;
  padding: 8px 12px;
  border-radius: 8px;
  font-size: 0.85rem;
  pointer-events: none;
  z-index: 100;
  line-height: 1.6;
  backdrop-filter: blur(4px);
  border: 1px solid rgba(255,255,255,0.15);
"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
  const container = document.getElementById('mapa-container');

  const raycaster = new THREE.Raycaster();
  const mouse = new THREE.Vector2();
  const tooltip = document.getElementById('tooltip');
  let blocoMeshes = [];

  const scene = new THREE.Scene();
  scene.background = new THREE.Color(0x87ceeb);

  const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
  camera.position.set(0, 80, 120);
  camera.lookAt(0, 0, 0);

  const renderer = new THREE.WebGLRenderer({ antialias: true });
  renderer.setSize(container.clientWidth, container.clientHeight);
  renderer.shadowMap.enabled = true;
  renderer.setPixelRatio(window.devicePixelRatio); 
  container.appendChild(renderer.domElement);


  window.addEventListener('resize', () => {
    camera.aspect = container.clientWidth / container.clientHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(container.clientWidth, container.clientHeight);
  });

  const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
  scene.add(ambientLight);

  const groundGeo = new THREE.PlaneGeometry(500, 500);
  const groundMat = new THREE.MeshLambertMaterial({ color: 0x2d4a22 });
  const ground = new THREE.Mesh(groundGeo, groundMat);
  ground.rotation.x = -Math.PI / 2;
  ground.receiveShadow = true;
  scene.add(ground);

  const BLOCOS_POR_LINHA = 5;
  const LARGURA_UNIDADE = 4;
  const ALTURA_ANDAR = 3;
  const PROFUNDIDADE_BLOCO = 1;
  const MAX_UNIDADES_LARGURA = 10;
  const GAP_X = 6;
  const GAP_Z = 12;

  const CORES = [0x4a90d9, 0xe67e22, 0x27ae60, 0x8e44ad, 0xe74c3c,
                 0x16a085, 0xf39c12, 0x2980b9, 0xc0392b, 0x1abc9c];

  let isDragging = false;
  let prevMouse = { x: 0, y: 0 };
  let spherical = { theta: 0, phi: Math.PI / 4, radius: 140 };

  fetch('/mapa/dados')
    .then(r => r.json())
    .then(blocos => {
      const totalLinhas = Math.ceil(blocos.length / BLOCOS_POR_LINHA);
      const raioIdeal = Math.max(140, totalLinhas * 30 + blocos.length * 2);
      spherical.radius = raioIdeal;

      const getLayout = (unidades) => {
        const colsLargura = Math.min(unidades, MAX_UNIDADES_LARGURA);
        const colsProfundidade = Math.ceil(unidades / MAX_UNIDADES_LARGURA);
        return { colsLargura, colsProfundidade };
      };

      const larguras = blocos.map(b => getLayout(b.unidades_por_andar).colsLargura * LARGURA_UNIDADE);
      const profundidades = blocos.map(b => getLayout(b.unidades_por_andar).colsProfundidade * LARGURA_UNIDADE);

      const linhas = [];
      for (let l = 0; l < totalLinhas; l++) {
        const inicio = l * BLOCOS_POR_LINHA;
        const fim = Math.min(inicio + BLOCOS_POR_LINHA, blocos.length);
        const blocosLinha = larguras.slice(inicio, fim);
        const larguraTotal = blocosLinha.reduce((acc, w) => acc + w, 0) + (blocosLinha.length - 1) * GAP_X;
        const maxProfLinha = profundidades.slice(inicio, fim).reduce((a, b) => Math.max(a, b), 0);
        linhas.push({ larguraTotal, count: fim - inicio, maxProfLinha });
      }

      const zPorLinha = [];
      let zAtual = 0;
      for (let l = 0; l < totalLinhas; l++) {
        zPorLinha.push(zAtual);
        zAtual += linhas[l].maxProfLinha + GAP_Z;
      }
      const alturaGrid = zAtual - GAP_Z;

      blocos.forEach((bloco, i) => {
        const col = i % BLOCOS_POR_LINHA;
        const linhaIdx = Math.floor(i / BLOCOS_POR_LINHA);
        const larguraBloco = larguras[i];
        const profundidadeBloco = profundidades[i];
        const alturaBloco = bloco.quantidade_andares * ALTURA_ANDAR;
        const { colsLargura, colsProfundidade } = getLayout(bloco.unidades_por_andar);

        const inicioLinha = linhaIdx * BLOCOS_POR_LINHA;
        let xAcumulado = 0;
        for (let c = 0; c < col; c++) {
          xAcumulado += larguras[inicioLinha + c] + GAP_X;
        }

        const offsetX = linhas[linhaIdx].larguraTotal / 2;
        const x = xAcumulado - offsetX + larguraBloco / 2;

        const offsetZ = alturaGrid / 2;
        const z = zPorLinha[linhaIdx] - offsetZ + profundidadeBloco / 2;

        const geo = new THREE.BoxGeometry(larguraBloco, alturaBloco, profundidadeBloco);
        const mat = new THREE.MeshLambertMaterial({ color: CORES[i % CORES.length] });
        const mesh = new THREE.Mesh(geo, mat);
        mesh.userData = {
          nome: bloco.nome,
          andares: bloco.quantidade_andares,
          unidades: bloco.unidades_por_andar,
          total: bloco.quantidade_andares * bloco.unidades_por_andar
        };
        mesh.position.set(x, alturaBloco / 2, z);
        mesh.castShadow = true;
        mesh.receiveShadow = true;
        scene.add(mesh);
        blocoMeshes.push(mesh);

        for (let a = 1; a < bloco.quantidade_andares; a++) {
          const lGeo = new THREE.BoxGeometry(larguraBloco + 0.1, 0.15, profundidadeBloco + 0.1);
          const lMat = new THREE.MeshBasicMaterial({ color: 0x000000, opacity: 0.3, transparent: true });
          const linha3d = new THREE.Mesh(lGeo, lMat);
          linha3d.position.set(x, a * ALTURA_ANDAR, z);
          scene.add(linha3d);
        }

        for (let u = 1; u < colsLargura; u++) {
          const vGeo = new THREE.BoxGeometry(0.15, alturaBloco + 0.1, profundidadeBloco + 0.1);
          const vMat = new THREE.MeshBasicMaterial({ color: 0x000000, opacity: 0.3, transparent: true });
          const vertical = new THREE.Mesh(vGeo, vMat);
          const xDiv = (x - larguraBloco / 2) + u * LARGURA_UNIDADE;
          vertical.position.set(xDiv, alturaBloco / 2, z);
          scene.add(vertical);
        }

        for (let p = 1; p < colsProfundidade; p++) {
          const pGeo = new THREE.BoxGeometry(larguraBloco + 0.1, alturaBloco + 0.1, 0.15);
          const pMat = new THREE.MeshBasicMaterial({ color: 0x000000, opacity: 0.3, transparent: true });
          const parede = new THREE.Mesh(pGeo, pMat);
          const zDiv = (z - profundidadeBloco / 2) + p * LARGURA_UNIDADE;
          parede.position.set(x, alturaBloco / 2, zDiv);
          scene.add(parede);
        }

        const topoGeo = new THREE.BoxGeometry(larguraBloco + 0.5, 0.4, profundidadeBloco + 0.5);
        const topoMat = new THREE.MeshLambertMaterial({ color: 0x888888 });
        const topo = new THREE.Mesh(topoGeo, topoMat);
        topo.position.set(x, alturaBloco + 0.2, z);
        scene.add(topo);
      });

      
      const padding = 20; 

      
      const maxLarguraGrid = Math.max(...linhas.map(l => l.larguraTotal));
      const meioProfGrid = alturaGrid / 2;

      const muroW = maxLarguraGrid + padding * 2;
      const muroD = alturaGrid + padding * 2;

      const dirLight = new THREE.DirectionalLight(0xffffff, 1);
      dirLight.position.set(100, 200, 100);
      dirLight.castShadow = true;
      dirLight.shadow.mapSize.width = 4096;
      dirLight.shadow.mapSize.height = 4096;
      dirLight.shadow.camera.near = 1;
      dirLight.shadow.camera.far = 1000;
      dirLight.shadow.camera.left   = -(muroW / 2 + 50);
      dirLight.shadow.camera.right  =  (muroW / 2 + 50);
      dirLight.shadow.camera.top    =  (muroD / 2 + 50);
      dirLight.shadow.camera.bottom = -(muroD / 2 + 50);
      dirLight.shadow.bias = -0.001;
      scene.add(dirLight);

      const muroH = 4;
      const muroEspessura = 1.5;

      const muroMat = new THREE.MeshLambertMaterial({ color: 0xd4b896 });

      const calcadaGeo = new THREE.PlaneGeometry(muroW, muroD);
      const calcadaMat = new THREE.MeshLambertMaterial({
        color: 0x9e9e9e,
        polygonOffset: true,
        polygonOffsetFactor: -1,
        polygonOffsetUnits: -1
      });
      const calcada = new THREE.Mesh(calcadaGeo, calcadaMat);
      calcada.rotation.x = -Math.PI / 2;
      calcada.position.set(0, 0.05, 0);
      calcada.receiveShadow = true;
      scene.add(calcada);

      const muroNGeo = new THREE.BoxGeometry(muroW + muroEspessura * 2, muroH, muroEspessura);
      const muroN = new THREE.Mesh(muroNGeo, muroMat);
      muroN.position.set(0, muroH / 2, -muroD / 2);
      muroN.castShadow = true;
      muroN.receiveShadow = true;
      scene.add(muroN);

      const muroS = muroN.clone();
      muroS.position.set(0, muroH / 2, muroD / 2);
      scene.add(muroS);

      const muroLGeo = new THREE.BoxGeometry(muroEspessura, muroH, muroD);
      const muroL = new THREE.Mesh(muroLGeo, muroMat);
      muroL.position.set(muroW / 2, muroH / 2, 0);
      muroL.castShadow = true;
      muroL.receiveShadow = true;
      scene.add(muroL);

      const muroO = muroL.clone();
      muroO.position.set(-muroW / 2, muroH / 2, 0);
      scene.add(muroO);

      const pilarGeo = new THREE.BoxGeometry(3, muroH + 2, muroEspessura);
      const pilarMat = new THREE.MeshLambertMaterial({ color: 0xb0b0b0 });
      const pilarE = new THREE.Mesh(pilarGeo, pilarMat);
      pilarE.position.set(-8, (muroH + 2) / 2, muroD / 2 + muroEspessura / 2);
      pilarE.castShadow = true;
      scene.add(pilarE);

      const pilarD = pilarE.clone();
      pilarD.position.set(8,  (muroH + 2) / 2, muroD / 2 + muroEspessura / 2);
      scene.add(pilarD);

      const tampaGeo = new THREE.BoxGeometry(muroW + muroEspessura * 2 + 0.5, 0.4, muroEspessura + 0.5);
      const tampaMat = new THREE.MeshLambertMaterial({ color: 0xc0a882 });

      ['N', 'S'].forEach(lado => {
        const tampa = new THREE.Mesh(tampaGeo, tampaMat);
        tampa.position.set(0, muroH + 0.2, lado === 'N' ? -muroD / 2 : muroD / 2);
        scene.add(tampa);
      });

      const tampaLGeo = new THREE.BoxGeometry(muroEspessura + 0.5, 0.4, muroD + 0.5);
      ['L', 'O'].forEach(lado => {
        const tampa = new THREE.Mesh(tampaLGeo, tampaMat);
        tampa.position.set(lado === 'L' ? muroW / 2 : -muroW / 2, muroH + 0.2, 0);
        scene.add(tampa);
      });
    });

  container.addEventListener('mousedown', e => { isDragging = true; prevMouse = { x: e.clientX, y: e.clientY }; });
  container.addEventListener('mouseup', () => isDragging = false);
  container.addEventListener('mousemove', e => {
    if (!isDragging) return;
    const dx = e.clientX - prevMouse.x;
    const dy = e.clientY - prevMouse.y;
    spherical.theta -= dx * 0.005;
    spherical.phi = Math.max(0.1, Math.min(Math.PI / 2.2, spherical.phi - dy * 0.005));
    prevMouse = { x: e.clientX, y: e.clientY };
  });
  container.addEventListener('wheel', e => {
    spherical.radius = Math.max(40, Math.min(1000, spherical.radius + e.deltaY * 0.2));
  });

  container.addEventListener('mousemove', e => {
    if (isDragging) {
      tooltip.style.display = 'none';
      return;
    }

    const rect = container.getBoundingClientRect();
    mouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
    mouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;

    raycaster.setFromCamera(mouse, camera);
    const intersects = raycaster.intersectObjects(blocoMeshes);

    if (intersects.length > 0) {
      const dados = intersects[0].object.userData;
      tooltip.style.display = 'block';
      tooltip.style.left = (e.clientX + 14) + 'px';
      tooltip.style.top = (e.clientY - 10) + 'px';
      tooltip.innerHTML = `
        <strong>${dados.nome}</strong><br>
        Andares: ${dados.andares}<br>
        Unidades por andar: ${dados.unidades}<br>
        Total de unidades: ${dados.andares * dados.unidades}
      `;
      container.style.cursor = 'pointer';
    } else {
      tooltip.style.display = 'none';
      container.style.cursor = 'default';
    }
  });

  container.addEventListener('mouseleave', () => {
    tooltip.style.display = 'none';
  });

  function animate() {
    requestAnimationFrame(animate);
    camera.position.x = spherical.radius * Math.sin(spherical.phi) * Math.sin(spherical.theta);
    camera.position.y = spherical.radius * Math.cos(spherical.phi);
    camera.position.z = spherical.radius * Math.sin(spherical.phi) * Math.cos(spherical.theta);
    camera.lookAt(0, 0, 0);
    renderer.render(scene, camera);
  }
  animate();
</script>