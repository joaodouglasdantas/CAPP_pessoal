<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold" style="color: #a78bfa;">Blocos</h1>
  <%= link_to "Novo Bloco", new_bloco_path,
      class: "px-4 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition",
      style: "background-color: #7c3aed;" %>
</div>

<div class="rounded-xl overflow-hidden" style="background-color: #1a2e4a; border: 1px solid #2d4a6b;">
  <div class="overflow-x-auto">
    <table class="w-full table-fixed">
      <thead>
        <tr style="border-bottom: 1px solid #2d4a6b;">
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: #94a3b8;">Nome</th>
          <th class="px-4 py-3 text-left text-sm font-medium w-24 whitespace-nowrap" style="color: #94a3b8;">Andares</th>
          <th class="px-4 py-3 text-left text-sm font-medium w-40 whitespace-nowrap" style="color: #94a3b8;">Unidades por andar</th>
          <th class="px-4 py-3 text-left text-sm font-medium w-40 whitespace-nowrap" style="color: #94a3b8;">Total de unidades</th>
          <th class="px-4 py-3 text-left text-sm font-medium w-56" style="color: #94a3b8;">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @blocos.each do |bloco| %>
          <tr style="border-bottom: 1px solid #2d4a6b;">
            <td class="px-4 py-3 text-sm" style="color: #f1f5f9;">
              <span class="block truncate"
                    title="<%= bloco.nome %>"
                    style="cursor: help;">
                <%= bloco.nome %>
              </span>
            </td>
            <td class="px-4 py-3 text-sm" style="color: #f1f5f9;"><%= bloco.quantidade_andares %></td>
            <td class="px-4 py-3 text-sm" style="color: #f1f5f9;"><%= bloco.unidades_por_andar %></td>
            <td class="px-4 py-3 text-sm" style="color: #f1f5f9;"><%= bloco.unidades.count %></td>
            <td class="px-4 py-3">
              <div class="flex gap-2 flex-nowrap">
                <%= link_to "Ver", bloco,
                    class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                    style: "background-color: #1e3352; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
                <%= link_to "Editar", edit_bloco_path(bloco),
                    class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                    style: "background-color: #1e3352; border: 1px solid #a78bfa; color: #a78bfa;" %>
                <%= button_to "Remover", bloco_path(bloco), method: :delete,
                    data: { turbo_confirm: "Tem certeza?" },
                    class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition cursor-pointer",
                    style: "background-color: #1e3352; border: 1px solid #ef4444; color: #ef4444;" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>